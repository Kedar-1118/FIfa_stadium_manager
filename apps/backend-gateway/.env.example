# =============================================================================
# StadiumOS AI — Backend Gateway Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# NEVER commit .env to version control.
# =============================================================================

# --- Application ---
APP_NAME=StadiumOS AI Gateway
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=true

# --- Server ---
HOST=0.0.0.0
PORT=8000
WORKERS=1
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# --- PostgreSQL Database ---
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://stadiumos:stadiumos_secret@localhost:5432/stadiumos_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_ECHO=false

# --- Redis Cache ---
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50

# --- JWT Authentication ---
JWT_SECRET_KEY=CHANGE_ME_TO_A_RANDOM_64_CHAR_HEX_STRING
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=60

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json
