# =============================================================================
# StadiumOS AI Gateway — Environment Configurations
# =============================================================================

# Server
PORT=8000
NODE_ENV=development
APP_NAME="StadiumOS AI Gateway"

# Database Connection (Prisma URL format)
# Note: Direct connection URL for migrations, pooling connection for queries
DATABASE_URL="postgresql://stadiumos:stadiumos_secret@localhost:5432/stadiumos_db?schema=public"

# Redis Cache connection
REDIS_URL="redis://localhost:6379/0"

# JWT Config (Generate a strong 32-character key for production)
JWT_SECRET_KEY="dev-only-insecure-key-change-in-production-minimum-32-chars"
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Rate Limiting
RATE_LIMIT_PER_MINUTE=120

# Agent Mesh Coordination
AGENT_MESH_URL="http://localhost:8001/api/v1/agents"
INTERNAL_SERVICE_KEY="gateway-agent-secret-handshake"

# Logging Level: debug, info, warn, error
LOG_LEVEL=debug
LOG_FORMAT=console
